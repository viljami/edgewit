{
  "openapi": "3.1.0",
  "info": {
    "title": "Edgewit API",
    "description": "Lightweight, Rust-based search and analytics engine for edge environments. Implements a focused subset of the OpenSearch API.",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": ["cluster"],
        "summary": "Handler for the root endpoint, emulating the default OpenSearch response",
        "operationId": "root_handler",
        "responses": {
          "200": {
            "description": "OpenSearch compatible greeting",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/_bulk": {
      "post": {
        "tags": ["ingest"],
        "summary": "Handler for OpenSearch compatible bulk ingestion",
        "operationId": "bulk_handler",
        "responses": {
          "200": {
            "description": "Bulk documents ingested successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to write to WAL"
          }
        }
      }
    },
    "/_cat/indexes": {
      "get": {
        "tags": ["cluster"],
        "summary": "Handler for the cat indexes endpoint (/_cat/indexes)",
        "operationId": "cat_indexes_handler",
        "responses": {
          "200": {
            "description": "List of indexes with stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CatIndex"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/_health": {
      "get": {
        "tags": ["cluster"],
        "summary": "Handler for the cluster health endpoint (/_health or /_cluster/health)",
        "operationId": "health_handler",
        "responses": {
          "200": {
            "description": "Cluster health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/_stats": {
      "get": {
        "tags": ["cluster"],
        "summary": "Handler for the statistics endpoint (/_stats)",
        "operationId": "stats_handler",
        "responses": {
          "200": {
            "description": "Cluster and index statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/indexes": {
      "get": {
        "tags": ["indexes"],
        "operationId": "list_indexes_handler",
        "responses": {
          "200": {
            "description": "List of all index definitions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndexDefinition"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/indexes/{index}": {
      "get": {
        "tags": ["indexes"],
        "operationId": "get_index_handler",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index definition returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexDefinition"
                }
              }
            }
          },
          "404": {
            "description": "Index not found"
          }
        }
      },
      "put": {
        "tags": ["indexes"],
        "operationId": "create_index_handler",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndexDefinition"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Index created/updated successfully"
          },
          "400": {
            "description": "Invalid schema"
          },
          "403": {
            "description": "API management disabled"
          }
        }
      },
      "delete": {
        "tags": ["indexes"],
        "operationId": "delete_index_handler",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Index deleted successfully"
          },
          "403": {
            "description": "API management disabled"
          },
          "404": {
            "description": "Index not found"
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": [],
        "operationId": "metrics_handler",
        "responses": {
          "200": {
            "description": "Prometheus compatible metrics",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{index}/_doc": {
      "post": {
        "tags": ["ingest"],
        "summary": "Handler for ingesting a single document",
        "operationId": "ingest_doc_handler",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "description": "Index name to ingest into",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Document ingested successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to write to WAL"
          }
        }
      }
    },
    "/indexes/{index}/_search": {
      "get": {
        "tags": ["search"],
        "summary": "OpenSearch `/indexes/:index/_search` endpoint (searches a specific index)",
        "operationId": "index_search_handler",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results for index"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CatIndex": {
        "type": "object",
        "required": [
          "health",
          "status",
          "index",
          "uuid",
          "pri",
          "rep",
          "docs.count",
          "docs.deleted",
          "store.size",
          "pri.store.size"
        ],
        "properties": {
          "docs.count": {
            "type": "string"
          },
          "docs.deleted": {
            "type": "string"
          },
          "health": {
            "type": "string"
          },
          "index": {
            "type": "string"
          },
          "pri": {
            "type": "string"
          },
          "pri.store.size": {
            "type": "string"
          },
          "rep": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "store.size": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          }
        }
      },
      "CompressionOption": {
        "type": "string",
        "enum": ["none", "zstd", "lz4"]
      },
      "DocsStats": {
        "type": "object",
        "required": ["count", "deleted"],
        "properties": {
          "count": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "deleted": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "FieldDefinition": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "default": {},
          "fast": {
            "type": "boolean"
          },
          "indexed": {
            "type": "boolean"
          },
          "optional": {
            "type": "boolean"
          },
          "stored": {
            "type": "boolean"
          },
          "type": {
            "$ref": "#/components/schemas/FieldType"
          }
        }
      },
      "FieldType": {
        "type": "string",
        "enum": [
          "text",
          "keyword",
          "datetime",
          "integer",
          "float",
          "boolean",
          "bytes"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "cluster_name",
          "status",
          "timed_out",
          "number_of_nodes",
          "active_primary_shards",
          "active_shards"
        ],
        "properties": {
          "active_primary_shards": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "active_shards": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "cluster_name": {
            "type": "string"
          },
          "number_of_nodes": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "status": {
            "type": "string"
          },
          "timed_out": {
            "type": "boolean"
          }
        }
      },
      "IndexDefinition": {
        "type": "object",
        "required": ["name", "fields"],
        "properties": {
          "compression": {
            "$ref": "#/components/schemas/CompressionOption"
          },
          "description": {
            "type": ["string", "null"]
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/FieldDefinition"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "mode": {
            "$ref": "#/components/schemas/SchemaMode"
          },
          "name": {
            "type": "string"
          },
          "partition": {
            "$ref": "#/components/schemas/PartitionStrategy"
          },
          "retention": {
            "type": ["string", "null"]
          },
          "settings": {
            "type": "object",
            "additionalProperties": {},
            "propertyNames": {
              "type": "string"
            }
          },
          "timestamp_field": {
            "type": "string"
          }
        }
      },
      "IndexStats": {
        "type": "object",
        "required": ["docs", "store"],
        "properties": {
          "docs": {
            "$ref": "#/components/schemas/DocsStats"
          },
          "store": {
            "$ref": "#/components/schemas/StoreStats"
          }
        }
      },
      "IndicesStats": {
        "type": "object",
        "required": ["primaries", "total"],
        "properties": {
          "primaries": {
            "$ref": "#/components/schemas/IndexStats"
          },
          "total": {
            "$ref": "#/components/schemas/IndexStats"
          }
        }
      },
      "PartitionStrategy": {
        "type": "string",
        "enum": ["none", "daily", "hourly", "monthly"]
      },
      "SchemaMode": {
        "type": "string",
        "enum": ["strict", "drop_unmapped", "dynamic"]
      },
      "SearchRequestBody": {
        "type": "object",
        "properties": {
          "aggs": {},
          "from": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "query": {},
          "size": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "sort": {}
        }
      },
      "ShardsInfo": {
        "type": "object",
        "required": ["total", "successful", "skipped", "failed"],
        "properties": {
          "failed": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "skipped": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "successful": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "StatsResponse": {
        "type": "object",
        "required": ["_shards", "_all"],
        "properties": {
          "_all": {
            "$ref": "#/components/schemas/IndicesStats"
          },
          "_shards": {
            "$ref": "#/components/schemas/ShardsInfo"
          }
        }
      },
      "StoreStats": {
        "type": "object",
        "required": ["size_in_bytes"],
        "properties": {
          "size_in_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      }
    }
  }
}
